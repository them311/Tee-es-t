# ============================================================================
# SNB / LFDS — single source of truth for environment variables.
# Copy to .env and fill the keys you actually use; everything is optional and
# falls back to sane defaults when unset.
# ============================================================================

# ---------------------------- Runtime ---------------------------------------
APP_NAME=snb
ENV=dev                 # dev | staging | prod
DEBUG=true
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false          # true = JSON lines (prod/aggregators)

HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3

# ---------------------------- LFDS Quiz (existing) --------------------------
LFDS_API_KEY=
PORT=3001

# ---------------------------- Database --------------------------------------
DB_URL=sqlite+aiosqlite:///./snb.db
DB_ECHO=false
DB_POOL_SIZE=5

# For docker-compose dev stack:
# DB_URL=postgresql+asyncpg://snb:snb@localhost:5432/snb

# ---------------------------- Redis / Queue ---------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------- LLM providers ---------------------------------
LLM_ANTHROPIC_API_KEY=
LLM_OPENAI_API_KEY=
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# ---------------------------- Gmail (OAuth2) --------------------------------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=

# ---------------------------- Airtable --------------------------------------
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ---------------------------- HubSpot ---------------------------------------
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# ---------------------------- Shopify ---------------------------------------
SHOPIFY_SHOP_DOMAIN=         # your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-10

# ---------------------------- Notion ----------------------------------------
NOTION_TOKEN=
NOTION_ROOT_PAGE_ID=

# ---------------------------- Google Sheets ---------------------------------
# Either an absolute path to a service-account JSON file, or the raw JSON inline.
GSHEETS_SERVICE_ACCOUNT_JSON=
