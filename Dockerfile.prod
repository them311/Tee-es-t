## Production image for snb API + scheduled agents.
## Two entrypoints share the same image:
##   - default CMD          -> uvicorn API on $PORT
##   - "snb scheduler"      -> background agent loop
##
## Multi-stage build keeps the final image slim (~180MB) while still
## shipping the queue + api extras for real-world use.

FROM python:3.12-slim-bookworm AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY pyproject.toml README.md ./
COPY snb ./snb

RUN pip install --prefix=/install -U pip wheel \
 && pip install --prefix=/install ".[api,queue,llm]"

# ---------- runtime ----------
FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8080 \
    LOG_LEVEL=INFO \
    LOG_JSON=true

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
    && rm -rf /var/lib/apt/lists/* \
    && useradd -u 1000 -m snb

COPY --from=builder /install /usr/local
WORKDIR /app
COPY --chown=snb:snb snb ./snb
COPY --chown=snb:snb pyproject.toml README.md ./

USER snb

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -fsS "http://localhost:${PORT}/health" || exit 1

CMD ["sh", "-c", "uvicorn snb.api.app:app --host 0.0.0.0 --port ${PORT}"]
