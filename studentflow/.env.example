# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# --- France Travail API (ex Pôle Emploi) ---
# https://francetravail.io/data/api/offres-emploi
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# --- Agents ---
SCRAPER_INTERVAL_SECONDS=900     # 15 min
MATCHER_INTERVAL_SECONDS=60      # 1 min
NOTIFIER_INTERVAL_SECONDS=30     # 30 s
MATCH_SCORE_THRESHOLD=0.6        # score minimum pour créer un match

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Notifications (webhook générique) ---
NOTIFICATION_WEBHOOK_URL=
