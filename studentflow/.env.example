# ============================================================================
# StudentFlow — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill every non-commented value.
# On Railway / Fly / Render, paste these as "variables" in the project dashboard
# instead of committing a .env file.
# ============================================================================

# ---- Supabase (required for production) ------------------------------------
# 1. Create a project at https://supabase.com
# 2. Open SQL editor and paste the content of `studentflow/schema.sql`
# 3. Project Settings → API → copy the URL and the `service_role` key (NOT anon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ---- France Travail API (ex Pôle Emploi) -----------------------------------
# Free, official, OAuth2 client_credentials.
# 1. Create an account on https://francetravail.io
# 2. Create an app and subscribe to the "Offres d'emploi v2" API
# 3. Paste the client_id and client_secret below
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# ---- Adzuna API ------------------------------------------------------------
# Free, official, simple query-string auth. 1000 calls/month on the free tier.
# 1. Register at https://developer.adzuna.com
# 2. Get your app_id + app_key from the dashboard
# 3. ADZUNA_COUNTRY is a 2-letter code: fr, gb, us, de, es, it, nl, pl, br, in…
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=fr

# ---- Jooble API ------------------------------------------------------------
# Free, official, one API key. Returns results from many sub-boards.
# 1. Register at https://jooble.org/api/about
# 2. Paste the single API key below
# 3. JOOBLE_LOCATION restricts the search to a city/country (default: France)
JOOBLE_API_KEY=
JOOBLE_LOCATION=France

# ---- Agents (safe defaults, tune for your traffic) -------------------------
SCRAPER_INTERVAL_SECONDS=900     # 15 min between scrape cycles
MATCHER_INTERVAL_SECONDS=60      # 1 min — score new offers against students
NOTIFIER_INTERVAL_SECONDS=30     # 30 s — push unnotified matches
MATCH_SCORE_THRESHOLD=0.6        # only create matches above this score

# ---- API -------------------------------------------------------------------
# Railway / Fly override $PORT automatically; keep API_HOST=0.0.0.0.
API_HOST=0.0.0.0
API_PORT=8000
# Public base URL — used to build the accept/decline links embedded in every
# notification email. In dev, keep the default; in prod, set it to the
# public hostname of the API (https://api.studentflow.fr or the Railway URL).
PUBLIC_BASE_URL=http://localhost:8000

# ---- Notifications ---------------------------------------------------------
# Three channels, selected in this priority order at startup:
#   1. Email (SMTP)  — preferred, reaches the student directly
#   2. Webhook       — bridge to Make / Zapier / n8n / Discord / Slack
#   3. Null          — dev default, just logs (safe fallback)
#
# --- 1) SMTP email (recommended) --------------------------------------------
# Works with any provider: Gmail app-password, Fastmail, OVH, SendGrid SMTP
# relay, Brevo (ex-Sendinblue), Mailgun, Infomaniak…
# Set at least SMTP_HOST and SMTP_FROM to enable the email channel.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- 2) Webhook (fallback) --------------------------------------------------
# Generic JSON POST. Body shape:
#   { match_id, offer_id, student_id, student_email, student_full_name,
#     offer_title, offer_company, offer_city, offer_url, score, reasons, sent_at }
# Only used when SMTP is NOT configured.
NOTIFICATION_WEBHOOK_URL=
