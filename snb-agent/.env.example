# SNB Mission Hunter — Environment Variables
# Copy to .env and fill in values

# Required
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional but recommended
ANTHROPIC_API_KEY=

# Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bp.thevenot@gmail.com
SMTP_PASSWORD=
EMAIL_TO=bp.thevenot@gmail.com

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Agent config
SCORE_THRESHOLD=70
SCAN_INTERVAL_FAST=300
SCAN_INTERVAL_SLOW=1800
LOG_LEVEL=INFO
ACTIVE_PROFILE=baptiste
